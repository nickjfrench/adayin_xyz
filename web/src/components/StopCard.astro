---
import MapLink from "./MapLink.astro";
import CostPill from "./CostPill.astro";

interface Props {
  stop: {
    _type: string;
    title?: string;
    time?: string;
    description?: string;
    cost?: number;
    address?: string;
    callouts?: Array<{
      kind?: {
        name?: string;
        label?: string;
        accent?: string;
        labelColor?: string;
        icon?: { provider: string; name: string; svg?: string };
      };
      body: string;
    }>;
    travelType?: {
      label: string;
      name: string;
      icon?: { provider: string; name: string; svg?: string };
    };
    duration?: string;
  };
  index: number;
}

const { stop, index } = Astro.props;

const isTravel = stop._type === "travel";
const isStart = stop._type === "startLocation";
const isEnd = stop._type === "endLocation";

const CONFIG: Record<string, { accent: string; dot: string; label: string; dim: boolean }> = {
  stop:          { accent: "border-sea-400",   dot: "bg-sea-500",   label: "",      dim: false },
  startLocation: { accent: "border-green-400", dot: "bg-green-500", label: "Start", dim: false },
  endLocation:   { accent: "border-sand-400",  dot: "bg-sand-500",  label: "End",   dim: false },
  travel:        { accent: "",                  dot: "bg-sea-300",   label: "",      dim: true  },
};

const config = CONFIG[stop._type] ?? CONFIG.stop;

const dotLabel = isStart ? "S" : isEnd ? "E" : null;

const mapsLink = stop.address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(stop.address)}`
  : null;
---

<li class:list={["relative pb-8 last:pb-0", config.dim && "opacity-60"]} data-travel={isTravel || undefined}>
  {/* Continuous rail line — styled via <style> below */}
  {/* Dot — centered on the rail line */}
  <div class="absolute left-[10px] top-2 z-10 -translate-x-1/2">
    <span
      class:list={[
        "flex h-5 w-5 items-center justify-center rounded-full text-white",
        config.dot,
        dotLabel ? "text-[10px] font-bold" : "ring-[3px] ring-white",
      ]}
    >
      {dotLabel ? (
        dotLabel
      ) : isTravel && stop.travelType?.icon?.svg ? (
        <span class="travel-icon inline-block h-3 w-3" set:html={stop.travelType.icon.svg} />
      ) : isTravel ? (
        <span class="text-[10px] font-bold">→</span>
      ) : (
        /* Map pin icon for stops */
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
      )}
    </span>
  </div>

  {/* ── Content column ── */}
  <div class="min-w-0 flex-1 pl-8">
    {isTravel ? (
      /* ── Travel connector: lightweight inline row ── */
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 py-1.5">
        <span class="text-xs font-medium text-sea-500">
          {stop.travelType?.label ?? "Travel"}
          {stop.duration && <span class="text-sea-300"> · {stop.duration}</span>}
        </span>
        {stop.title && (
          <>
            <span class="text-sea-300">·</span>
            <span class="text-xs text-sea-600">{stop.title}</span>
          </>
        )}
        {stop.cost != null && stop.cost > 0 && (
          <>
            <span class="text-sea-300">·</span>
            <CostPill cost={stop.cost} />
          </>
        )}
        {mapsLink && (
          <>
            <span class="text-sea-300">·</span>
            <MapLink address={stop.address!} class="text-sea-400 hover:text-sea-600" />
          </>
        )}
      </div>
    ) : (
      /* ── Stop / Location: white card with accent stripe ── */
      <div class:list={[
        "rounded-l-[3px] rounded-r-lg bg-white shadow-sm",
        "border-l-[3px]",
        config.accent,
      ]}>
        <div class="px-4 py-3">
          {/* Sub-label */}
          {(stop.time || isStart || isEnd) && (
            <p class:list={[
              "font-display text-xs font-semibold uppercase tracking-widest",
              isStart ? "text-green-600" : isEnd ? "text-sand-500" : "text-sand-500",
            ]}>
              {isStart ? "Start" : isEnd ? "End" : stop.time}
            </p>
          )}

          {/* Title + Cost inline */}
          <div class="mt-0.5 flex flex-wrap items-center gap-2">
            <h3 class="font-display text-lg font-semibold leading-snug text-sea-800">
              {stop.title}
            </h3>
            {stop.cost != null && stop.cost > 0 && (
              <CostPill cost={stop.cost} />
            )}
          </div>

          {/* Callouts */}
          {stop.callouts && stop.callouts.length > 0 && (
            <div class="mt-2.5 flex flex-col gap-1.5">
              {stop.callouts.map((callout) => (
                <p class="flex items-start gap-2 text-sm text-sea-700">
                  {callout.kind?.icon?.svg ? (
                    <span
                      class:list={["inline-block h-3.5 w-3.5 shrink-0 mt-0.5 [&>svg]:h-full [&>svg]:w-full", callout.kind?.labelColor ?? "text-sand-500"]}
                      set:html={callout.kind.icon.svg}
                    />
                  ) : (
                    <span class:list={["mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full", callout.kind?.labelColor ?? "bg-sand-400"]} />
                  )}
                  <span>{callout.body}</span>
                </p>
              ))}
            </div>
          )}

          {/* Description */}
          {stop.description && (
            <p class="mt-2.5 text-sm leading-relaxed text-deep/60">
              {stop.description}
            </p>
          )}

          {/* Address */}
          {mapsLink && (
            <div class="mt-2.5">
              <MapLink address={stop.address!} class="text-sea-400 hover:text-sea-600" />
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</li>

<style>
  /* Continuous timeline rail — runs dot-to-dot, hidden after last item */
  li::before {
    content: '';
    position: absolute;
    left: 9px;        /* 10px dot center minus 1px (half of 2px line) */
    top: 0;
    bottom: 0;
    width: 0;
    border-left: 2px solid var(--color-sea-200, #bfe0e6);
    z-index: 0;
  }
  li:last-child::before {
    display: none;
  }
  li[data-travel]::before {
    border-left-style: dashed;
  }
  /* Font Awesome SVGs injected via set:html need global targeting */
  :global(.travel-icon svg) {
    height: 0.75rem !important;
    width: 0.75rem !important;
  }
</style>
