---
interface Props {
  stop: {
    _type: string;
    title?: string;
    time?: string;
    description?: string;
    cost?: number;
    address?: string;
    callouts?: Array<{
      kind?: {
        name?: string;
        label?: string;
        accent?: string;
        labelColor?: string;
        icon?: { provider: string; name: string; svg?: string };
      };
      body: string;
    }>;
    travelType?: {
      label: string;
      name: string;
      icon?: { provider: string; name: string; svg?: string };
    };
    duration?: string;
  };
  index: number;
}

const { stop, index } = Astro.props;

const STYLES: Record<string, { dot: string; opacity: string }> = {
  stop: {
    dot: "bg-gradient-to-br from-sand-300 to-sea-500",
    opacity: "",
  },
  startLocation: {
    dot: "bg-gradient-to-br from-green-300 to-green-500",
    opacity: "",
  },
  endLocation: {
    dot: "bg-gradient-to-br from-sand-400 to-sand-500",
    opacity: "",
  },
  travel: {
    dot: "bg-sea-100",
    opacity: "opacity-60",
  },
};

const style = STYLES[stop._type] ?? STYLES.stop;

const mapsLink = stop.address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(stop.address)}`
  : null;
---

<li class={`relative pb-10 last:pb-0 ${style.opacity}`}>
  <!-- Timeline dot -->
  <span
    class={`absolute -left-[39px] flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-bold text-white ring-4 ring-foam ${style.dot}`}
  >
    {stop._type === "startLocation" ? "S" : stop._type === "endLocation" ? "E" : stop._type === "travel" ? "→" : index + 1}
  </span>

  {stop._type === "stop" && (
    <>
      {stop.time && (
        <p class="font-display text-xs font-semibold uppercase tracking-widest text-sand-500">
          {stop.time}
        </p>
      )}
      <h3 class="mt-0.5 font-display text-lg font-semibold text-sea-800 underline decoration-sea-300 decoration-wavy decoration-2 underline-offset-[0.35em]">
        {stop.title}
      </h3>
      {stop.description && (
        <p class="mt-1.5 leading-relaxed text-deep/80">{stop.description}</p>
      )}
      {stop.callouts?.length > 0 &&
        stop.callouts.map((c) => (
          <p
            class={`mt-3 flex gap-2 rounded-lg bg-sand-100 px-3 py-2 text-sm text-sea-800 border-l-[3px] ${c.kind?.accent ?? "border-sand-300"}`}
          >
            <span
              class={`font-display font-semibold shrink-0 flex items-center gap-1 ${c.kind?.labelColor ?? "text-sand-500"}`}
            >
              {c.kind?.icon?.svg && (
                <span
                  class="inline-block w-4 h-4 [&>svg]:w-full [&>svg]:h-full"
                  set:html={c.kind.icon.svg}
                />
              )}
              {c.kind?.label ?? c.kind?.name}
            </span>
            <span>{c.body}</span>
          </p>
        ))}
      {stop.cost != null && stop.cost > 0 && (
        <span class="mt-2 inline-block rounded-full bg-sand-100 px-2.5 py-0.5 text-xs font-medium text-sand-600">
          ${stop.cost}
        </span>
      )}
      {mapsLink && (
        <a
          href={mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex items-center gap-1 text-xs text-sea-500 hover:text-sea-400 transition-colors"
        >
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
          {stop.address}
        </a>
      )}
    </>
  )}

  {(stop._type === "startLocation" || stop._type === "endLocation") && (
    <>
      <p class="font-display text-xs font-semibold uppercase tracking-widest text-sand-500">
        {stop._type === "startLocation" ? "Start" : "End"}
      </p>
      <h3 class="mt-0.5 font-display text-lg font-semibold text-sea-800">
        {stop.title}
      </h3>
      {mapsLink && (
        <a
          href={mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 inline-flex items-center gap-1 text-xs text-sea-500 hover:text-sea-400 transition-colors"
        >
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
          {stop.address}
        </a>
      )}
    </>
  )}

  {stop._type === "travel" && (
    <>
      <p class="flex items-center gap-1.5 font-display text-xs font-semibold uppercase tracking-widest text-sea-400">
        {stop.travelType?.icon?.svg && (
          <span
            class="inline-block w-3.5 h-3.5 [&>svg]:w-full [&>svg]:h-full"
            set:html={stop.travelType.icon.svg}
          />
        )}
        {stop.travelType?.label ?? "Travel"}
        {stop.duration && <span class="text-sea-300">· {stop.duration}</span>}
      </p>
      <h3 class="mt-0.5 font-display text-base font-medium text-sea-600">
        {stop.title}
      </h3>
      {stop.description && (
        <p class="mt-1 text-sm leading-relaxed text-sea-500">{stop.description}</p>
      )}
      {mapsLink && (
        <a
          href={mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 inline-flex items-center gap-1 text-xs text-sea-400 hover:text-sea-300 transition-colors"
        >
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
          {stop.address}
        </a>
      )}
    </>
  )}
</li>
