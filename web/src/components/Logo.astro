---
import logoSvg from "../assets/logo.svg?raw"
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<a href="/" class={`group inline-flex items-center gap-3 ${className}`} aria-label="A Day In — home">
  <span class="h-10 w-10 shrink-0 [&>svg]:h-full [&>svg]:w-full transition-transform duration-500 group-hover:rotate-12" set:html={logoSvg} />
  <span class="font-display text-xl font-semibold tracking-tight text-sea-700">
    A DAY IN <span class="text-sand-300">.xyz</span>
  </span>
</a>
