---
// A DAY IN .xyz wordmark + line-art globe with a dotted flight path.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<a href="/" class={`group inline-flex items-center gap-3 ${className}`} aria-label="A Day In — home">
  <svg
    class="h-10 w-10 shrink-0 text-sea-500 transition-transform duration-500 group-hover:rotate-12"
    viewBox="0 0 48 48"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="24" cy="24" r="17" fill="var(--color-sea-100)" stroke="currentColor" />
    <!-- continents (loose blobs) -->
    <path d="M14 18c2-1 4 0 5 2s-1 4 1 5 4-2 5 0-2 4-4 4-5-2-7-4-1-5 0-7Z" fill="var(--color-sea-300)" stroke="none" opacity="0.9" />
    <path d="M30 14c3 0 5 2 4 4s-3 1-3 3 2 3 0 4-3-2-3-4 0-7 2-7Z" fill="var(--color-sea-300)" stroke="none" opacity="0.9" />
    <!-- meridians -->
    <ellipse cx="24" cy="24" rx="7" ry="17" stroke="currentColor" opacity="0.4" />
    <line x1="7" y1="24" x2="41" y2="24" stroke="currentColor" opacity="0.4" />
    <!-- dotted flight path arc -->
    <path d="M11 31C18 20 30 19 38 12" stroke="var(--color-sand-500)" stroke-dasharray="0.5 3.2" stroke-width="2" />
    <!-- location pin -->
    <path d="M38 8c2 0 3.4 1.5 3.4 3.4 0 2.3-3.4 5.6-3.4 5.6s-3.4-3.3-3.4-5.6C34.6 9.5 36 8 38 8Z" fill="var(--color-sand-400)" stroke="var(--color-sea-600)" stroke-width="1.2" />
    <circle cx="38" cy="11.3" r="1.1" fill="var(--color-foam)" stroke="none" />
  </svg>
  <span class="font-display text-xl font-semibold tracking-tight text-sea-700">
    A DAY IN <span class="text-sand-500">.xyz</span>
  </span>
</a>
