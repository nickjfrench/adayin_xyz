---
import Logo from "./Logo.astro";

interface Props {
  // Render transparent over a hero, or solid on inner pages.
  variant?: "overlay" | "solid";
}
const { variant = "solid" } = Astro.props;
const path = Astro.url.pathname;

const links = [
  { label: "Home", href: "/" },
  { label: "Destinations", href: "/destinations" },
  { label: "Blog", href: "/posts" },
  { label: "About Us", href: "/about" },
];

const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class:list={[
    "z-30 w-full",
    variant === "overlay"
      ? "absolute inset-x-0 top-0"
      : "sticky top-0 border-b border-sea-100 bg-foam/85 backdrop-blur-md",
  ]}
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 sm:px-8">
    <Logo />

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "font-display text-[0.95rem] font-medium transition-colors",
                isActive(link.href)
                  ? "text-sea-600"
                  : "text-sea-800/80 hover:text-sea-500",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile menu toggle -->
    <details class="relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center rounded-lg p-2 text-sea-700 hover:bg-sea-50">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </summary>
      <ul class="absolute right-0 mt-2 w-44 rounded-xl border border-sea-100 bg-foam p-2 shadow-lg shadow-sea-900/10">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "block rounded-lg px-3 py-2 font-display text-sm font-medium",
                  isActive(link.href)
                    ? "bg-sea-50 text-sea-600"
                    : "text-sea-800/80 hover:bg-sea-50",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </nav>
</header>
