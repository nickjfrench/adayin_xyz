---
import Logo from "./Logo.astro";
import GlassLink from "./GlassLink.astro";

interface Props {
  /** "light" = glass nav with white text over a dark hero; "dark" = glass nav with dark text (default). */
  variant?: "light" | "dark";
}
const { variant = "dark" } = Astro.props;
const path = Astro.url.pathname;

const links = [
  { label: "Destinations", href: "/destinations" },
  { label: "Itineraries", href: "/itineraries" },
  { label: "Articles", href: "/articles" },
  { label: "About Us", href: "/about" },
];

const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  id="site-header"
  data-variant={variant}
  class="group fixed inset-x-0 top-0 z-30 px-4 pt-3 transition-all duration-300 sm:px-6 sm:pt-4"
>
  <nav
    id="site-nav"
    class="mx-auto flex max-w-6xl items-center justify-between rounded-full border border-white/25 bg-foam/25 px-5 py-4 shadow-lg backdrop-blur-md transition-all duration-300 group-data-[variant=dark]:shadow-sea-900/5 sm:px-7"
  >
    <Logo class="header-logo" variant={variant} />

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {links.map((link) => (
        <li>
          <GlassLink
            href={link.href}
            label={link.label}
            active={isActive(link.href)}
            variant={variant}
            class=""
          />
        </li>
      ))}
    </ul>

    <!-- Mobile menu toggle -->
    <details class="relative md:hidden">
      <summary
        class="flex cursor-pointer list-none items-center rounded-lg p-2 transition-colors group-data-[variant=light]:text-white/90 group-data-[variant=light]:hover:bg-white/10 group-data-[variant=dark]:text-sea-700 group-data-[variant=dark]:hover:bg-sea-50"
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </summary>
      <ul
        class="absolute right-0 mt-2 w-44 rounded-xl border border-sea-100 bg-foam p-2 shadow-lg shadow-sea-900/10"
      >
        {links.map((link) => (
          <li>
            <GlassLink
              href={link.href}
              label={link.label}
              active={isActive(link.href)}
              variant="dark"
              class:list={[
                "block rounded-lg px-3 py-2 text-sm",
                isActive(link.href) ? "bg-sea-50" : "hover:bg-sea-50",
              ]}
            />
          </li>
        ))}
      </ul>
    </details>
  </nav>
</header>

<!--
  JS-toggled states (.scrolled, data-variant) and custom transition timings
  that can't be expressed cleanly in Tailwind live here.
-->
<style is:global>
  /* ── Transition timings ── */
  #site-header {
    transition: padding-top 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #site-nav {
    transition:
      padding 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s ease,
      background-color 0.35s ease;
  }
  #site-header .header-logo > svg {
    transition:
      height 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      width 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.5s ease;
  }
  #site-header .header-logo > span {
    transition: font-size 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Scrolled (compact) state ── */
  #site-header.scrolled {
    padding-top: 0.5rem;
  }
  @media (min-width: 640px) {
    #site-header.scrolled {
      padding-top: 0.625rem;
    }
  }
  #site-header.scrolled #site-nav {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }
  #site-header.scrolled .header-logo > svg {
    height: 2rem;
    width: 2rem;
  }
  #site-header.scrolled .header-logo > span {
    font-size: 1.125rem;
  }

  /* ── Variant: light/dark driven by data-variant attribute ── */
  #site-header[data-variant="light"] {
    color: white;
    text-shadow: 0 -1px 0 rgba(255, 255, 255, 0.25), 0 1px 2px rgba(0, 0, 0, 0.2);
  }
  #site-header[data-variant="dark"] {
    color: var(--color-sea-800);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.6);
  }
</style>

<script>
  // Compact state on scroll-down, full size on scroll-up. Hysteresis (dead
  // band between 6 and 12px) prevents flutter at the threshold; the header is
  // position:fixed so its resize never feeds back into scrollY.
  // Also flips data-variant light → dark when the hero scrolls away.
  let header = document.getElementById("site-header");
  let scrolled = false;
  const update = () => {
    if (!header || !document.body.contains(header)) {
      header = document.getElementById("site-header");
    }
    if (!header) return;

    const y = window.scrollY;
    if (!scrolled && y > 12) scrolled = true;
    else if (scrolled && y < 6) scrolled = false;
    header.classList.toggle("scrolled", scrolled);

    const heroEl = document.getElementById("hero-section");
    if (heroEl) {
      header.dataset.variant =
        heroEl.getBoundingClientRect().bottom <= header.offsetHeight ? "dark" : "light";
    }
  };
  window.addEventListener("scroll", update, { passive: true });
  window.addEventListener("astro:page-load", update);
  update();
</script>
