---
interface Props {
  address: string;
  class?: string;
}

const { address, class: className = "" } = Astro.props;

const mapsLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
---

<a
  href={mapsLink}
  target="_blank"
  rel="noopener noreferrer"
  class={`inline-flex items-center gap-1 text-xs transition-colors ${className}`}
>
  <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
  {address}
</a>
