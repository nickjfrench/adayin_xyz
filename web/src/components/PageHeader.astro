---
interface Props {
  label: string;
  title: string;
  description: string;
}

const { label, title, description } = Astro.props;
---

<div class="border-b border-sea-100 bg-foam">
  <div class="mx-auto max-w-6xl px-5 pt-36 pb-14 sm:px-8">
    <p class="font-display text-sm font-semibold uppercase tracking-widest text-sand-500">
      {label}
    </p>
    <h1 class="mt-2 font-display text-4xl font-semibold text-sea-800">{title}</h1>
    <p class="mt-3 max-w-xl text-deep/70">{description}</p>
  </div>
</div>
