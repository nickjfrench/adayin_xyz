---
import Logo from "./Logo.astro";
import GlassLink from "./GlassLink.astro";

interface Props {
  /** "light" = white text on dark glass (default); "dark" = dark text on light glass. */
  variant?: "light" | "dark";
}

const { variant = "light" } = Astro.props;
const year = new Date().getFullYear();

const links = [
  { label: "Destinations", href: "/destinations" },
  { label: "Itineraries", href: "/itineraries" },
  { label: "Articles", href: "/articles" },
  { label: "About Us", href: "/about" },
];
---

<footer
  id="site-footer"
  data-variant={variant}
  class="group mt-24 bg-sea-700 border-t border-white/10 text-white"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-5 py-12 sm:px-8 md:flex-row md:items-start md:justify-between">
    <div class="max-w-sm">
      <Logo variant={variant} />
      <p class="mt-3 text-sm leading-relaxed text-white/60">
        Tested day-itineraries for off-the-beaten-track places. Every route
        walked, timed and vouched for by us.
      </p>
    </div>

    <nav class="flex flex-col gap-3">
      <span class="font-display text-xs font-semibold uppercase tracking-widest text-sand-300">Explore</span>
      {
        links.map((link) => (
          <GlassLink
            href={link.href}
            label={link.label}
            variant={variant}
            class="text-sm"
          />
        ))
      }
    </nav>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-5 py-5 text-xs text-white/50 sm:px-8">
      © {year} A Day In
    </div>
  </div>
</footer>

<style is:global>
  #site-footer {
    transition: background-color 0.35s ease, border-color 0.35s ease;
  }
</style>
