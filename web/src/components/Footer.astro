---
const year = new Date().getFullYear();
const links = [
  { label: "Home", href: "/" },
  { label: "Destinations", href: "/destinations" },
  { label: "Itineraries", href: "/itineraries" },
  { label: "About Us", href: "/about" },
];
---

<footer class="mt-24 border-t border-sea-100 bg-sea-800 text-sea-100">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-5 py-12 sm:px-8 md:flex-row md:items-start md:justify-between">
    <div class="max-w-sm">
      <p class="font-display text-lg font-semibold text-white">
        A DAY IN <span class="text-sand-300">.xyz</span>
      </p>
      <p class="mt-3 text-sm leading-relaxed text-sea-200">
        Tested day-itineraries for off-the-beaten-track places. Every route
        walked, timed and vouched for by us.
      </p>
    </div>

    <nav class="flex flex-col gap-3">
      <span class="font-display text-xs font-semibold uppercase tracking-widest text-sand-300">Explore</span>
      {
        links.map((link) => (
          <a href={link.href} class="text-sm text-sea-100 transition-colors hover:text-sand-300">
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="border-t border-sea-700/60">
    <div class="mx-auto max-w-6xl px-5 py-5 text-xs text-sea-300 sm:px-8">
      © {year} A Day In · Made with sea breeze & Sanity.
    </div>
  </div>
</footer>
