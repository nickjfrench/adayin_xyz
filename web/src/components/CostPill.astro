---
import { costRange } from "../utils/cost";

interface Props {
  cost: number;
  class?: string;
}

const { cost, class: className = "" } = Astro.props;
---

<span
  class={`inline-block rounded-full bg-sand-100 px-2.5 py-0.5 text-xs font-semibold text-sand-600 ${className}`}
  title={costRange(cost)}
>
  ${cost}
</span>
