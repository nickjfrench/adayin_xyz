---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPosts } from "../../utils/sanity";

const posts = await getPosts();
---

<BaseLayout title="The Journal — A Day In">
  <header class="border-b border-sea-100 bg-sea-50/60">
    <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
      <p class="font-display text-sm font-semibold uppercase tracking-widest text-sand-500">
        The itineraries
      </p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-sea-800">Every tested day, one place at a time</h1>
      <p class="mt-3 max-w-xl text-deep/70">
        Browse all of our “A day in…” itineraries — each one walked and timed by us. Want just one place? <a href="/destinations" class="text-sea-600 underline underline-offset-2">Pick a destination →</a>
      </p>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    {
      posts.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-sea-200 bg-sea-50/50 p-10 text-center">
          <p class="font-display text-lg font-semibold text-sea-700">No stories yet</p>
          <p class="mt-2 text-sm text-deep/60">
            Add one in the Studio (<code class="rounded bg-sea-100 px-1.5 py-0.5">cd studio && bun run dev</code>).
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
