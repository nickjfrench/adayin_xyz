---
import { PortableText } from "astro-portabletext";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticle, getArticleSlugs, urlFor } from "../../utils/sanity";

export async function getStaticPaths() {
  return await getArticleSlugs();
}

const { slug } = Astro.params;
const article = await getArticle(slug as string);

if (!article) {
  return Astro.redirect("/articles");
}

const dest = article.destination;
const post = article.post;
const date = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString("en-AU", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

const hero = article.mainImage
  ? urlFor(article.mainImage).width(1600).height(900).fit("crop").auto("format").url()
  : null;
---

<BaseLayout title={`${article.title} — A Day In`} description={article.excerpt} headerVariant="light">
  <article>
    <!-- Hero -->
    <header id="hero-section" class="relative isolate flex min-h-[50vh] items-end overflow-hidden">
      <div class="absolute inset-0 -z-10">
        {
          hero ? (
            <img
              src={hero}
              alt={article.title ?? ""}
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="h-full w-full bg-gradient-to-br from-sea-200 to-sea-400" />
          )
        }
        <div class="absolute inset-0 bg-gradient-to-t from-sea-900/80 via-sea-900/30 to-transparent" />
      </div>
      <div class="mx-auto w-full max-w-2xl px-5 pb-10 sm:px-8">
        {
          dest && (
            <a href={`/?dest=${dest.slug?.current}`} class="mb-3 inline-block rounded-full bg-foam/90 px-3 py-1 font-display text-xs font-semibold text-sea-700 backdrop-blur-sm">
              {dest.city}{dest.countryShort ? `, ${dest.countryShort}` : ""}
            </a>
          )
        }
        {
          post && !dest && (
            <a href={`/itineraries/${post.slug?.current}`} class="mb-3 inline-block rounded-full bg-foam/90 px-3 py-1 font-display text-xs font-semibold text-sea-700 backdrop-blur-sm">
              {post.title}
            </a>
          )
        }
        <h1 class="font-display text-3xl font-bold leading-tight text-white drop-shadow sm:text-4xl">
          {article.title}
        </h1>
        {date && <p class="mt-3 text-sm text-white/80">{date}</p>}
      </div>
    </header>

    <!-- Body -->
    <div class="mx-auto max-w-2xl px-5 py-12 sm:px-8">
      {
        article.body ? (
          <div class="prose-sea prose prose-lg max-w-none">
            <PortableText value={article.body} />
          </div>
        ) : (
          <div class="rounded-2xl border border-dashed border-sea-200 bg-sea-50/50 p-10 text-center">
            <p class="text-sm text-deep/60">This article has no body content yet.</p>
          </div>
        )
      }

      {
        (dest || post) && (
          <footer class="mt-16 border-t border-sea-100 pt-8">
            <p class="text-sm text-deep/50">Attached to</p>
            <div class="mt-3 flex flex-wrap gap-3">
              {dest && (
                <a
                  href={`/?dest=${dest.slug?.current}`}
                  class="inline-flex items-center gap-2 rounded-full border border-sea-200 bg-sea-50 px-4 py-2 text-sm font-medium text-sea-700 transition-colors hover:bg-sea-100"
                >
                  {dest.city}, {dest.country}
                </a>
              )}
              {post && (
                <a
                  href={`/itineraries/${post.slug?.current}`}
                  class="inline-flex items-center gap-2 rounded-full border border-sea-200 bg-sea-50 px-4 py-2 text-sm font-medium text-sea-700 transition-colors hover:bg-sea-100"
                >
                  {post.title}
                </a>
              )}
            </div>
          </footer>
        )
      }
    </div>
  </article>
</BaseLayout>
