---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getArticles, urlFor } from "../../utils/sanity";

const articles = await getArticles();
---

<BaseLayout title="Articles — A Day In" headerVariant="dark">
  <PageHeader
    label="Stories & notes"
    title="Articles"
    description="Longer reads, travel notes, and whatever else doesn't fit a day itinerary."
  />

  <section class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    {
      articles.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-sea-200 bg-sea-50/50 p-10 text-center">
          <p class="font-display text-lg font-semibold text-sea-700">No articles yet</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {articles.map((article) => {
            const img = article.mainImage
              ? urlFor(article.mainImage).width(800).height(560).fit("crop").auto("format").url()
              : null;
            const dest = article.destination;
            const post = article.post;
            return (
              <a
                href={`/articles/${article.slug?.current}`}
                class="group block overflow-hidden rounded-2xl border border-sea-100 bg-white shadow-sm shadow-sea-900/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-sea-900/10"
              >
                <div class="relative aspect-[4/3] overflow-hidden bg-sea-100">
                  {
                    img ? (
                      <img
                        src={img}
                        alt={article.title ?? ""}
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sea-200 to-sea-400">
                        <span class="font-display text-2xl font-semibold text-white/80">A Day In</span>
                      </div>
                    )
                  }
                  {
                    (dest || post) && (
                      <span class="absolute left-3 top-3 rounded-full bg-foam/90 px-3 py-1 font-display text-xs font-semibold text-sea-700 backdrop-blur-sm">
                        {dest ? `${dest.city}${dest.countryShort ? `, ${dest.countryShort}` : ""}` : post?.title}
                      </span>
                    )
                  }
                  <!-- Blur band: softens the bottom of the image for text legibility -->
                  <div class="absolute inset-x-0 bottom-0 h-8 backdrop-blur-[4px]" style="-webkit-mask-image:linear-gradient(to top,black 50%,transparent 100%);mask-image:linear-gradient(to top,black 50%,transparent 100%)"></div>
                </div>
                <div class="p-5">
                  <h3 class="font-display text-lg font-semibold leading-snug text-sea-800 group-hover:text-sea-600">
                    {article.title}
                  </h3>
                  {article.excerpt && <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-deep/70">{article.excerpt}</p>}
                </div>
              </a>
            );
          })}
        </div>
      )
    }
  </section>
</BaseLayout>
