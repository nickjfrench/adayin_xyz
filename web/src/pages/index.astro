---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ItineraryCard from "../components/ItineraryCard.astro";
import { getDestinations, getItineraries } from "../utils/sanity";

const destinations = await getDestinations();
const posts = await getItineraries();
---

<BaseLayout headerVariant="overlay">
  <Hero destinations={destinations} />

  <!-- Destinations strip -->
  {
    destinations.length > 0 && (
      <section class="mx-auto -mt-10 max-w-6xl px-5 sm:px-8">
        <div class="flex flex-wrap gap-3 rounded-2xl border border-sea-100 bg-white/90 p-4 shadow-lg shadow-sea-900/5 backdrop-blur">
          <button
            type="button"
            data-dest="all"
            class="dest-jump rounded-full bg-sea-500 px-4 py-2 font-display text-sm font-semibold text-white transition hover:bg-sea-600"
          >
            All
          </button>
          {destinations.map((d) => (
            <button
              type="button"
              data-dest={d.slug?.current}
              data-city={d.city}
              class="dest-jump rounded-full border border-sea-100 px-4 py-2 font-display text-sm font-medium text-sea-700 transition hover:border-sea-300 hover:bg-sea-50"
            >
              {d.city}
              <span class="ml-1 text-xs text-sand-500">{d.postCount ?? 0}</span>
            </button>
          ))}
        </div>
      </section>
    )
  }

  <!-- Stories grid -->
  <section id="stories" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-16 sm:px-8">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="font-display text-sm font-semibold uppercase tracking-widest text-sand-500">
          The itineraries
        </p>
        <h2 id="stories-heading" class="mt-1 font-display text-3xl font-semibold text-sea-800">
          Latest day plans
        </h2>
      </div>
      <a
        href="/itineraries"
        class="hidden shrink-0 font-display text-sm font-medium text-sea-600 hover:text-sea-500 sm:inline"
        >View all →</a
      >
    </div>

    {
      posts.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-sea-200 bg-sea-50/50 p-10 text-center">
          <p class="font-display text-lg font-semibold text-sea-700">No itineraries yet</p>
          <p class="mt-2 text-sm text-deep/60">
            Add a day itinerary in the Studio (<code class="rounded bg-sea-100 px-1.5 py-0.5">cd studio && bun run dev</code>)
            and link it to a destination.
          </p>
        </div>
      ) : (
        <>
          <div id="stories-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <ItineraryCard post={post} />
            ))}
          </div>
          <p
            id="stories-empty"
            hidden
            class="rounded-2xl border border-dashed border-sea-200 bg-sea-50/50 p-10 text-center text-sm text-deep/60"
          >
            No tested itineraries from this place yet — check back soon.
          </p>
        </>
      )
    }
  </section>
</BaseLayout>

<script>
  // Orchestrates the hero destination cycle + the dropdown filter for the grid.
  const trigger = document.getElementById("dest-trigger");
  const label = document.getElementById("dest-label");
  const menu = document.getElementById("dest-menu");
  const bgLayers = Array.from(document.querySelectorAll<HTMLElement>(".hero-bg"));
  const heading = document.getElementById("stories-heading");
  const empty = document.getElementById("stories-empty");

  const dests = Array.from(document.querySelectorAll<HTMLElement>(".dest-option"))
    .filter((o) => o.dataset.index !== undefined)
    .map((o) => ({
      slug: o.dataset.dest!,
      city: o.dataset.city!,
      index: Number(o.dataset.index),
    }));

  let current = 0; // active hero index
  let manual = false; // user has chosen a destination → stop auto-cycle
  let menuOpen = false;

  function setHero(index: number) {
    if (!dests.length) return;
    current = ((index % dests.length) + dests.length) % dests.length;
    bgLayers.forEach((layer) => {
      layer.style.opacity = Number(layer.dataset.index) === current ? "1" : "0";
    });
    if (label) label.textContent = dests[current].city;
  }

  function filterGrid(slug: string, city?: string) {
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".post-card"));
    let visible = 0;
    cards.forEach((card) => {
      const show = slug === "all" || card.dataset.destination === slug;
      card.hidden = !show;
      if (show) visible++;
    });
    if (heading) heading.textContent = slug === "all" ? "Latest day plans" : `A day in ${city ?? ""}`;
    if (empty) empty.hidden = visible !== 0;
  }

  function syncUrl(slug: string) {
    const url = new URL(window.location.href);
    if (slug === "all") url.searchParams.delete("dest");
    else url.searchParams.set("dest", slug);
    history.replaceState({}, "", url);
  }

  function select(slug: string, opts: { scroll?: boolean } = {}) {
    closeMenu();
    if (slug === "all") {
      manual = false;
      filterGrid("all");
    } else {
      const d = dests.find((x) => x.slug === slug);
      if (!d) return;
      manual = true;
      setHero(d.index);
      filterGrid(slug, d.city);
    }
    syncUrl(slug);
    if (opts.scroll) document.getElementById("stories")?.scrollIntoView({ behavior: "smooth" });
  }

  // ── Dropdown open/close ──
  function openMenu() {
    if (!menu || !trigger) return;
    menu.hidden = false;
    trigger.setAttribute("aria-expanded", "true");
    menuOpen = true;
  }
  function closeMenu() {
    if (!menu || !trigger) return;
    menu.hidden = true;
    trigger.setAttribute("aria-expanded", "false");
    menuOpen = false;
  }

  trigger?.addEventListener("click", (e) => {
    e.stopPropagation();
    menuOpen ? closeMenu() : openMenu();
  });
  document.addEventListener("click", (e) => {
    if (menuOpen && !menu?.contains(e.target as Node)) closeMenu();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  // Hero dropdown options + destination strip chips both drive `select`.
  document.querySelectorAll<HTMLElement>(".dest-option").forEach((opt) => {
    opt.addEventListener("click", () => select(opt.dataset.dest!));
  });
  document.querySelectorAll<HTMLElement>(".dest-jump").forEach((chip) => {
    chip.addEventListener("click", () => select(chip.dataset.dest!, { scroll: true }));
  });

  // ── Auto-cycle the hero word/background until the user picks something ──
  if (dests.length) {
    setHero(0);
    setInterval(() => {
      if (!manual && !menuOpen && dests.length > 1) setHero(current + 1);
    }, 3800);
  }

  // ── Deep-link: /?dest=slug pre-selects a destination ──
  const initial = new URL(window.location.href).searchParams.get("dest");
  if (initial) select(initial);
</script>
