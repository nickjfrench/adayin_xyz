---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDestinations, urlFor } from "../../utils/sanity";

const destinations = await getDestinations();

const gradients = [
  "from-sea-300 to-sea-600",
  "from-sea-200 to-sea-500",
  "from-sand-300 to-sea-600",
  "from-sea-400 to-sea-800",
];
---

<BaseLayout title="Destinations — A Day In">
  <header class="border-b border-sea-100 bg-sea-50/60">
    <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
      <p class="font-display text-sm font-semibold uppercase tracking-widest text-sand-500">Where we've been</p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-sea-800">Destinations</h1>
      <p class="mt-3 max-w-xl text-deep/70">
        Off-the-beaten-track places, each with one tested day-itinerary. Tap a spot to filter its days.
      </p>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    {
      destinations.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-sea-200 bg-sea-50/50 p-10 text-center">
          <p class="font-display text-lg font-semibold text-sea-700">No destinations yet</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {destinations.map((d, i) => {
            const img = d.heroImage
              ? urlFor(d.heroImage).width(800).height(600).fit("crop").auto("format").url()
              : null;
            return (
              <a
                href={`/?dest=${d.slug?.current}`}
                class="group relative block aspect-[4/5] overflow-hidden rounded-2xl shadow-sm shadow-sea-900/10"
              >
                {img ? (
                  <img
                    src={img}
                    alt={d.city}
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class={`absolute inset-0 bg-gradient-to-br ${gradients[i % gradients.length]}`} />
                )}
                <!-- Blur band: softens the bottom of the image for text legibility -->
                <div class="absolute inset-x-0 bottom-0 h-1/2 backdrop-blur-[4px]" style="-webkit-mask-image:linear-gradient(to top,black 35%,transparent 70%);mask-image:linear-gradient(to top,black 35%,transparent 70%)"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-sea-900/80 via-transparent to-transparent" />
                <div class="absolute inset-x-0 bottom-0 p-5">
                  <h2 class="font-display text-2xl font-bold uppercase tracking-wide text-white drop-shadow">
                    {d.city}
                  </h2>
                  <p class="text-sm text-white/85">
                    {d.country}
                    <span class="ml-2 text-white/70">· {d.postCount ?? 0} {d.postCount === 1 ? "story" : "stories"}</span>
                  </p>
                  {d.blurb && <p class="mt-1 line-clamp-2 text-sm text-white/75">{d.blurb}</p>}
                </div>
              </a>
            );
          })}
        </div>
      )
    }
  </section>
</BaseLayout>
