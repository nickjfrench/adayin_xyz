---
import { PortableText } from "astro-portabletext";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getItinerary, getItinerarySlugs, urlFor } from "../../utils/sanity";
import { costIndicator } from "../../utils/cost";
import StopCard from "../../components/StopCard.astro";

export async function getStaticPaths() {
  // Queries used inside getStaticPaths must live here — module-scope consts
  // are not visible in this hoisted context.
  return await getItinerarySlugs();
}

const { slug } = Astro.params;
const post = await getItinerary(slug as string);

if (!post) {
  return Astro.redirect("/itineraries");
}

const dest = post.destination;
const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("en-AU", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

const testedOn = post.testedOn
  ? new Date(post.testedOn).toLocaleDateString("en-AU", { month: "long", year: "numeric" })
  : null;

const stops = post.stops ?? [];

const hero = post.mainImage
  ? urlFor(post.mainImage).width(1600).height(900).fit("crop").auto("format").url()
  : null;

---

<BaseLayout title={`${post.title} — A Day In`} description={post.excerpt} headerVariant="light">
  <article>
    <!-- Hero -->
    <header id="hero-section" class="relative isolate flex min-h-[50vh] items-end overflow-hidden">
      <div class="absolute inset-0 -z-10">
        {
          hero ? (
            <img src={hero} alt={post.title ?? ""} class="h-full w-full object-cover" />
          ) : (
            <div class="h-full w-full bg-gradient-to-br from-sea-300 to-sea-600" />
          )
        }
        <div class="absolute inset-0 bg-gradient-to-t from-sea-900/80 via-sea-900/30 to-sea-900/10"></div>
      </div>

      <div class="mx-auto w-full max-w-3xl px-5 pb-12 pt-32 sm:px-8">
        {
          dest && (
            <a
              href={`/?dest=${dest.slug?.current}`}
              class="inline-flex items-center gap-1.5 rounded-full bg-sea-500/95 px-3 py-1 font-display text-xs font-semibold uppercase tracking-wide text-white ring-1 ring-white/20 transition hover:bg-sea-500"
            >
              A day in {dest.city}
              {dest.countryShort && <span class="text-sea-100">· {dest.countryShort}</span>}
            </a>
          )
        }
        <h1 class="mt-4 font-display text-3xl font-semibold leading-tight text-white drop-shadow-md sm:text-5xl">
          {post.title}
        </h1>
        {date && <p class="mt-3 text-sm font-medium text-white/80">{date}</p>}
      </div>
    </header>

    <!-- Body -->
    <div class="mx-auto max-w-2xl px-5 py-12 sm:px-8">
      <!-- Tested-by-us meta strip -->
      <div class="mb-8 flex flex-wrap items-center gap-x-5 gap-y-2 rounded-xl bg-sea-50 px-5 py-4 text-sm text-sea-700">
        <span class="inline-flex items-center gap-1.5 font-display font-semibold text-sea-600">
          <svg class="h-4 w-4 text-sand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
          Tested by us
        </span>
        {post.duration && <span>· {post.duration}</span>}
        {stops.length > 0 && <span>· {stops.length} stops</span>}
        {post.totalCost != null && post.totalCost > 0 && <span>· {costIndicator(post.totalCost)}</span>}
        {testedOn && <span>· {testedOn}</span>}
        {post.testedBy && <span class="text-sea-500">· by {post.testedBy}</span>}
      </div>

      {post.excerpt && <p class="mb-10 border-l-4 border-sand-300 pl-4 text-lg italic text-sea-700">{post.excerpt}</p>}

      <!-- The itinerary, stop by stop -->
      {
        stops.length > 0 && (
          <section class="mb-16">
            <h2 class="mb-6 font-display text-2xl font-semibold text-sea-800">The day, stop by stop</h2>
            <ol class="relative border-l-2 border-sea-200 pl-8">
              {stops.map((stop, i) => (
                <StopCard stop={stop} index={i} />
              ))}
            </ol>
          </section>
        )
      }

      {
        post.body && (
          <div class="prose-sea border-t border-sea-100 pt-8">
            <h2 class="font-display text-2xl font-semibold text-sea-800">Closing Notes</h2>
            <PortableText value={post.body} />
          </div>
        )
      }

      <div class="mt-12 flex items-center justify-between border-t border-sea-100 pt-6">
        <a href="/itineraries" class="font-display text-sm font-medium text-sea-600 hover:text-sea-500">← All itineraries</a>
        {
          dest && (
            <a
              href={`/?dest=${dest.slug?.current}`}
              class="font-display text-sm font-medium text-sea-600 hover:text-sea-500"
            >
              More from {dest.city} →
            </a>
          )
        }
      </div>
    </div>
  </article>
</BaseLayout>
