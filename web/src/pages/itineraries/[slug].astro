---
import { PortableText } from "astro-portabletext";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getItinerary, getItinerarySlugs, urlFor } from "../../utils/sanity";
import { costIndicator, costRange } from "../../utils/cost";
import StopCard from "../../components/StopCard.astro";
import ExtendDayModal from "../../components/ExtendDayModal.svelte";

export async function getStaticPaths() {
  // Queries used inside getStaticPaths must live here — module-scope consts
  // are not visible in this hoisted context.
  return await getItinerarySlugs();
}

const { slug } = Astro.params;
const post = await getItinerary(slug as string);

if (!post) {
  return Astro.redirect("/itineraries");
}

const dest = post.destination;
const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("en-AU", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

const testedOn = post.testedOn
  ? new Date(post.testedOn).toLocaleDateString("en-AU", { month: "long", year: "numeric" })
  : null;

const stops = post.stops ?? [];
const stopCount = stops.filter((s) => s._type === 'stop').length;

const hero = post.mainImage
  ? urlFor(post.mainImage).width(1600).height(900).fit("crop").auto("format").url()
  : null;

const extendSlides = (post.extendDay ?? []).map((item) => ({
  id: item._key ?? item.title,
  title: item.title ?? '',
  description: item.shortDesc ?? '',
  link: item.link ?? '',
  imageUrl: item.image
    ? urlFor(item.image).width(1200).height(675).fit('crop').auto('format').url()
    : undefined,
}));


---

<BaseLayout title={`${post.title} — A Day In`} description={post.excerpt} headerVariant="light">
  <article>
    <!-- Hero -->
    <header id="hero-section" class="relative isolate flex min-h-[50vh] items-end overflow-hidden">
      <div class="absolute inset-0 -z-10">
        {
          hero ? (
            <img src={hero} alt={post.title ?? ""} class="h-full w-full object-cover" />
          ) : (
            <div class="h-full w-full bg-gradient-to-br from-sea-300 to-sea-600" />
          )
        }
        <div class="absolute inset-0 bg-gradient-to-t from-sea-900/80 via-sea-900/30 to-sea-900/10"></div>
      </div>

      <div class="mx-auto w-full max-w-4xl px-5 pb-16 pt-32 sm:px-8">
        {
          dest && (
            <a
              href={`/itineraries?dest=${dest.slug?.current}`}
              class="inline-flex items-center gap-1.5 rounded-full bg-sea-500/95 px-3 py-1 font-display text-xs font-semibold uppercase tracking-wide text-white ring-1 ring-white/20 transition hover:bg-sea-500"
            >
              A day in {dest.city}
              {dest.countryShort && <span class="text-sea-100">· {dest.countryShort}</span>}
            </a>
          )
        }
        <h1 class="mt-4 font-display text-3xl font-semibold leading-tight text-white drop-shadow-md sm:text-5xl">
          {post.title}
        </h1>
        <div class="mt-3 flex flex-wrap items-center gap-x-2 text-sm font-medium text-white/80">
          {post.testedBy && <span>by {post.testedBy}</span>}
          {post.testedBy && date && <span class="text-white/50">·</span>}
          {date && <span>{date}</span>}
        </div>
      </div>
    </header>

    <!-- Metadata overlay bar -->
    <div class="relative z-10 mx-auto -mt-8 flex w-full max-w-4xl flex-wrap items-center gap-y-2 rounded-xl bg-white/90 px-5 py-3 text-sm text-sea-700 shadow-lg shadow-sea-900/10 backdrop-blur-sm sm:px-8">
      <span class="inline-flex flex-2 items-center justify-center gap-1.5 whitespace-nowrap text-sea-600">
        <svg class="h-4 w-4 text-sand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
        <span class="font-display font-semibold">Tested by us</span>
        {testedOn && <span class="text-sea-700">· {testedOn}</span>}
      </span>
      {post.duration && <span class="flex-1 border-l border-sea-200 text-center">{post.duration}</span>}
      {stopCount > 0 && <span class="flex-1 border-l border-sea-200 text-center">{stopCount} stops</span>}
      {post.totalCost != null && post.totalCost > 0 && <span class="flex-1 border-l border-sea-200 text-center" title={costRange(post.totalCost)}>{costIndicator(post.totalCost)}</span>}
    </div>

    <!-- Body -->
    <div class="mx-auto max-w-4xl flex flex-col gap-10 px-5 pt-8 pb-16 sm:px-8">

      {post.excerpt && <p class="border-l-4 border-sand-300 pl-4 text-lg italic text-sea-700">{post.excerpt}</p>}

      <!-- The itinerary, stop by stop -->
      {
        stops.length > 0 && (
          <section class="border-t border-sea-100 pt-8">
            <h2 class="mb-6 font-display text-2xl font-semibold text-sea-800">The day, stop by stop</h2>
            <ol class="flex flex-col">
              {stops.map((stop, i) => (
                <StopCard stop={stop} index={i} />
              ))}
            </ol>
          </section>
        )
      }

      {
        post.closing && (
          <div class="border-t border-sea-100 pt-8">
            <h2 class="font-display text-2xl font-semibold text-sea-800">Closing notes</h2>
            <div class="prose-sea">
              <PortableText value={post.closing} />
            </div>
          </div>
        )
      }

      {
        post.extendDay && post.extendDay.length > 0 && (
          <section class="border-t border-sea-100 pt-8">
            <h2 class="mb-6 font-display text-2xl font-semibold text-sea-800">
              Extend your day
            </h2>
            <p class="mb-6">
              Want more? We have hand selected a few additional things for this itinerary if you wish to add to your day or switch things up.
            </p>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {post.extendDay.map((item, i) => (
                <button
                  data-extend-index={i}
                  class="group relative aspect-[16/10] cursor-pointer overflow-hidden rounded-xl shadow-sm shadow-sea-900/5 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md hover:shadow-sea-900/10"
                >
                  {item.image ? (
                    <img
                      src={urlFor(item.image).width(600).height(375).fit("crop").auto("format").url()}
                      alt={item.title ?? ""}
                      loading="lazy"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : (
                    <div class="absolute inset-0 bg-gradient-to-br from-sea-100 to-sea-200" />
                  )}
                  <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-sea-900/50 to-transparent p-3 pt-8">
                    <h3 class="font-display text-sm font-semibold leading-snug text-white drop-shadow-sm group-hover:underline">
                      {item.title}
                    </h3>
                    {item.shortDesc && (
                      <p class="mt-0.5 line-clamp-1 text-xs text-white/80">{item.shortDesc}</p>
                    )}
                  </div>
                </button>
              ))}
            </div>
          </section>
        )
      }

      <div class="flex items-center justify-between border-t border-sea-100 pt-8">
        <a href="/itineraries" class="font-display text-sm font-medium text-sea-600 hover:text-sea-500">← All itineraries</a>
        {
          dest && (
            <a
              href={`/itineraries?dest=${dest.slug?.current}`}
              class="font-display text-sm font-medium text-sea-600 hover:text-sea-500"
            >
              More from {dest.city} →
            </a>
          )
        }
      </div>
    </div>

    {extendSlides.length > 0 && (
      <ExtendDayModal client:load slides={extendSlides} />
    )}
  </article>

</BaseLayout>
